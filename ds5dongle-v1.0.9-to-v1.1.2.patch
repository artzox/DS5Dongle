+// The dongle can expose EXTRA HID interfaces with the same VID/PID: enabling
+// Wake (or the PS shortcut) adds a boot-keyboard interface for the wake key.
+// WebHID lists every interface as its own HIDDevice, and feature reports only
+// work on the GAMEPAD interface (top-level collection Generic Desktop/Game Pad
+// or the vendor-defined pages) - sending to the keyboard interface fails, which
+// broke profile auto-apply whenever Wake was on. Always select by collection,
+// never by VID/PID alone.
+function isWakeKeyboardIface(d){
+  // The wake feature adds a boot-keyboard HID interface with the same VID/PID.
+  // Only treat a device as that keyboard when it is UNAMBIGUOUSLY one (every
+  // top-level collection is Generic Desktop / Keyboard). Anything uncertain is
+  // kept - selection must never be stricter than the plain VID/PID matching
+  // that has always worked.
+  const cols = (d && d.collections) || [];
+  return cols.length > 0 && cols.every(c => c.usagePage === 0x01 && c.usage === 0x06);
+}
+function pickDs5(list){
+  const m = (list || []).filter(x => x && x.vendorId === SONY_VID
