+    return new Worker(URL.createObjectURL(new Blob([src], {type:'text/javascript'})));
+  } catch (_) { return null; } // fallback below keeps old behavior
+})();
+let _sleepSeq = 0;
+const _sleepWaiters = new Map();
+if (_sleepWorker) _sleepWorker.onmessage = (e) => {
+  const w = _sleepWaiters.get(e.data.id);
+  if (w) { _sleepWaiters.delete(e.data.id); w(); }
+};
+function sleep(ms){
+  if (!_sleepWorker) return new Promise(r => setTimeout(r, ms));
+  return new Promise(r => { const id = ++_sleepSeq; _sleepWaiters.set(id, r); _sleepWorker.postMessage({id, ms}); });
